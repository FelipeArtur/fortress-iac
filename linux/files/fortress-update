#!/usr/bin/env bash
# ==============================================================================
# Fortress IaC — Adult Content Shield & SafeSearch
# ==============================================================================
# Description:
#   Applies adult content filtering and forces SafeSearch mode on major search
#   engines (Google, Bing, DuckDuckGo) via /etc/hosts manipulation. 
#   Uses StevenBlack's public blocklist as the baseline.
#
# Scheduling:
#   Executed automatically via systemd timer.
#
# Local Entries:
#   To preserve local hosts (e.g., development IPs), add them to
#   /etc/hosts.local. It will be automatically merged at the top.
# ==============================================================================
set -e

if [ "$EUID" -ne 0 ]; then
    echo "[!] Access denied. Route manipulation requires elevation. Use sudo."
    exit 1
fi

URL="https://raw.githubusercontent.com/StevenBlack/hosts/master/alternates/porn/hosts"
HOSTS="/etc/hosts"
HOSTS_LOCAL="/etc/hosts.local"
BACKUP="/etc/hosts.bak"
TMP_DOWNLOAD="/tmp/hosts_stevenblack.tmp"
TMP_FINAL="/tmp/hosts_final.tmp"

# If it's the first run and the user lacks hosts.local, we create one
# with the current local configs (avoiding capturing the file if it's already StevenBlack's)
if [ ! -f "$HOSTS_LOCAL" ]; then
    echo ":: [1/6] Creating file for local hosts at $HOSTS_LOCAL..."
    if grep -q "StevenBlack" "$HOSTS"; then
        # If it already has StevenBlack, just create empty
        touch "$HOSTS_LOCAL"
    else
        # If not, we assume the current one is the original local file
        cp "$HOSTS" "$HOSTS_LOCAL"
    fi
fi

echo ":: [2/6] Downloading StevenBlack's blocklist matrix..."
if ! curl -sS "$URL" -o "$TMP_DOWNLOAD"; then
    echo "[!] Failed to download the list. Aborting."
    exit 1
fi

echo ":: [3/6] Preparing Local Entries..."
cat "$HOSTS_LOCAL" > "$TMP_FINAL"
echo "" >> "$TMP_FINAL"
echo "# ==========================================" >> "$TMP_FINAL"
echo "# FORTRESS: BLOCKLIST (StevenBlack)" >> "$TMP_FINAL"
echo "# ==========================================" >> "$TMP_FINAL"
cat "$TMP_DOWNLOAD" >> "$TMP_FINAL"

echo ":: [4/6] Injecting SafeSearch Module (Google, Bing, DuckDuckGo)..."

# Function to resolve DNS with fallback IP
resolve_safesearch() {
    local domain=$1
    local fallback=$2
    local ip
    ip=$(getent ahosts "$domain" | awk '{print $1}' | head -n 1 || true)
    if [ -z "$ip" ]; then
        echo "$fallback"
    else
        echo "$ip"
    fi
}

IP_GOOGLE=$(resolve_safesearch "forcesafesearch.google.com" "216.239.38.120")
IP_BING=$(resolve_safesearch "strict.bing.com" "204.79.197.220")
IP_DDG=$(resolve_safesearch "safe.duckduckgo.com" "107.20.240.232")

cat <<EOF >> "$TMP_FINAL"

# ==========================================
# FORTRESS: FORCED SAFESEARCH
# ==========================================
$IP_GOOGLE www.google.com
$IP_GOOGLE www.google.com.br
$IP_GOOGLE google.com
$IP_BING www.bing.com
$IP_BING bing.com
$IP_DDG duckduckgo.com
$IP_DDG www.duckduckgo.com
EOF

echo ":: [5/6] Applying atomic replacement to the hosts file..."
cp "$HOSTS" "$BACKUP"
mv "$TMP_FINAL" "$HOSTS"
chmod 644 "$HOSTS"
rm -f "$TMP_DOWNLOAD"

echo ":: [6/6] Flushing DNS resolution cache..."
if command -v resolvectl &> /dev/null; then
    resolvectl flush-caches
elif command -v systemd-resolve &> /dev/null; then
    systemd-resolve --flush-caches
elif command -v nmcli &> /dev/null; then
    systemctl restart NetworkManager
else
    echo "[!] No supported DNS cache manager found. Manual flush might be required."
fi

echo ">> Operation complete. Traffic blocked and Search Engines set to Strict mode."
